# === Unlink (Privacy Pool) ===
UNLINK_API_KEY=                    # https://hackaton-apikey.vercel.app/
AGENT_MNEMONIC=                    # BIP-39 mnemonic for Unlink ZK identity

# === EVM Wallet (pour deposits/approvals onchain) ===
EVM_PRIVATE_KEY=                   # 0x... private key of the EVM wallet holding USDC

# === Réseau ===
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# === Mock Server ===
MOCK_SERVER_PORT=4021
MOCK_RECEIVER_ADDRESS=             # Address that receives payments from the mock server
MOCK_RECEIVER_PRIVATE_KEY=         # Private key of the receiver (testnet only)

# === Gateway ===
GATEWAY_PORT=3000

# === Policy ===
DEFAULT_MAX_PER_TX=2

# === Backup Burner (parallel funding) ===
BACKUP_BURNER_PRIVATE_KEY=         # Optionnel — wallet qui fund les burners en parallèle du pool Unlink

# === Ledger (optionnel) ===
LEDGER_ORIGIN_TOKEN=
