# === Unlink (Privacy Pool) ===
UNLINK_API_KEY=                    # Get yours at https://hackaton-apikey.vercel.app/
AGENT_MNEMONIC=                    # BIP-39 mnemonic for Unlink ZK identity

# === EVM Wallet ===
EVM_PRIVATE_KEY=                   # 0x... private key holding USDC on Base Sepolia

# === Network ===
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# === Mock x402 Server ===
MOCK_SERVER_PORT=4021
MOCK_RECEIVER_ADDRESS=             # Address that receives x402 payments
MOCK_RECEIVER_PRIVATE_KEY=         # Testnet-only key for the mock receiver

# === Gateway ===
GATEWAY_PORT=3000

# === Policy ===
DEFAULT_MAX_PER_TX=2               # Max USDC per transaction (hard cap)

# === Backup Burner (optional — parallel funding) ===
BACKUP_BURNER_PRIVATE_KEY=         # Wallet that funds burners alongside the Unlink pool

# === Ledger / Speculos ===
LEDGER_MODE=speculos               # speculos | terminal
SPECULOS_HOST=http://127.0.0.1     # Use http://speculos in Docker Compose
SPECULOS_API_PORT=5001
